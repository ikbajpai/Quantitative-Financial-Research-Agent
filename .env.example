# LLM Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Model name
LLM_MODEL=claude-sonnet-4-6

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Financial Defaults
DEFAULT_RISK_FREE_RATE=0.0425
DEFAULT_BENCHMARK=^GSPC

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# News Sentiment (optional — leave blank to use yfinance headlines)
NEWS_API_KEY=your_newsapi_key_here

# LangSmith Observability (Feature 4)
# Get your key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=quant-financial-research-agent

# Logging
LOG_LEVEL=INFO
