# ─── LLM Provider ───────────────────────────────────────────────
# Choose one: "groq" (free), "anthropic", or "openai"
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# ─── API Keys ────────────────────────────────────────────────────
# Groq — FREE tier at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT-4o (optional)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Financial Defaults ──────────────────────────────────────────
DEFAULT_RISK_FREE_RATE=0.0425
DEFAULT_BENCHMARK=^GSPC

# ─── Cache ───────────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# ─── News Sentiment (optional — uses yfinance if blank) ──────────
NEWS_API_KEY=your_newsapi_key_here

# ─── LangSmith Observability (optional) ─────────────────────────
# Get your key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=quant-financial-research-agent

# ─── Google OAuth2 (optional — skip for dev/local mode) ─────────
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized JavaScript origins:  http://localhost:8000
# Authorized redirect URIs:       http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
SECRET_KEY=replace-with-a-random-32-char-string
BASE_URL=http://localhost:8000

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
